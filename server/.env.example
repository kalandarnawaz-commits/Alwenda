# Copy to server/.env (gitignored) and fill in real values.
# This file is loaded via `node --env-file=.env` — no dotenv dependency needed.

# Same Supabase project as the frontend's env.js — used here to verify a
# user's access token on every request, never to bypass Row Level Security.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Required for Alwen (OpenAI Agents SDK). Leave blank to run the server
# with Alwen disabled — /api/alwen/chat will respond with a clear
# "not configured" error instead of crashing or faking a reply.
OPENAI_API_KEY=

# Which frontend origin(s) may call this server. Comma-separated.
ALLOWED_ORIGINS=http://localhost:5173

PORT=8787
